    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "12.3.1" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
