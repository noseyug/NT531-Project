# Copy file này thành .env và điền vào các giá trị
# cp .env.example .env

# ── Bắt buộc ──────────────────────────────────────────────────────────────────
S3_BUCKET=lgtm-stack-bucket          # Tên S3 bucket dùng chung cho Loki/Tempo/Mimir
AWS_REGION=ap-southeast-1            # AWS region của bucket và EC2

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin               # Mật khẩu tài khoản admin Grafana

# ── Telegram Alerting (tuỳ chọn) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                  # Token từ @BotFather — để trống nếu không dùng
TELEGRAM_CHAT_ID=                    # Chat/Group ID — để trống nếu không dùng
